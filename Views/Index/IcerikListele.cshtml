@model List<Restorant_Sitesi.Models.ICERIKLER>
@{
    ViewBag.Title = "IcerikListele";
    Layout = "~/Views/Shared/RestourantLayout.cshtml";
}



<section class="hero-wrap hero-wrap-2" style="background-image: url('/images/bg_5.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-end justify-content-center">
            <div class="col-md-9 ftco-animate text-center mb-5">
                <h1 class="mb-2 bread"> Güncel İçerikler & Haberler </h1>
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Index/Index">Ana Sayfa <i class="fa fa-chevron-right"></i></a></span>
                    <span>İçerikler <i class="fa fa-chevron-right"></i></span>
                </p>
            </div>
        </div>
    </div>
</section>

<section class="ftco-section bg-light">
    <div class="container">
        <div class="row">
            @foreach (var x in Model.Where(m => m.Durum == true)) // Sadece aktif olanları gösterir
            {
                <div class="col-md-4 ftco-animate">
                    <div class="blog-entry" style="border-radius: 8px; overflow: hidden; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
                        @* Görsel Alanı - Dosyalar klasöründen çeker *@
                        <a href="/Index/IcerikGoster/@x.IcerikID" class="block-20"
                           style="background-image: url('/Dosyalar/@x.KFotograf'); background-size: cover; background-position: center;">
                        </a>

                        <div class="text px-4 pt-3 pb-4 bg-white">
                            <div class="meta mb-2">
                                <div style="font-size: 13px; color: #999;">
                                    <i class="fa fa-calendar mr-1"></i>
                                    @(x.Tarih.HasValue ? x.Tarih.Value.ToString("dd MMMM yyyy") : "Tarih Belirtilmedi")
                                </div>
                            </div>
                            
                            <h3 class="heading" style="font-size: 20px; font-weight: 600; line-height: 1.4;">
                                <a href="/Index/IcerikGoster/@x.IcerikID" style="color: #333;">@x.Baslik</a>
                            </h3>

                            <div class="d-flex align-items-center justify-content-between mt-4">
                                <a href="/Index/IcerikGoster/@x.IcerikID" class="btn btn-primary btn-sm" style="border-radius: 50px; padding: 8px 20px; font-weight: 600;">
                                    Devamını Oku
                                </a>

                                <div class="meta-icons d-flex align-items-center" style="gap: 15px; color: #ccc; font-size: 14px;">
                                    @* PDF veya Dosya varsa küçük bir ikon gösterir *@
                                    @if (!string.IsNullOrEmpty(x.Dosya) && x.Dosya.EndsWith(".pdf"))
                                    {
                                        <span title="PDF Dokümanı Mevcut">
                                            <i class="fa fa-file-pdf-o" style="color: #e74c3c;"></i>
                                        </span>
                                    }

                                    <span title="Moly RS">
                                        <i class="fa fa-user-circle-o"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any(m => m.Durum == true))
        {
            <div class="text-center py-5">
                <h4 class="text-muted">Henüz yayınlanmış bir içerik bulunmuyor.</h4>
            </div>
        }
    </div>
</section>