@model Restorant_Sitesi.Models.DUYURULABLOGLAR

<style>
    .rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center
    }

        .rating > input {
            display: none
        }

        .rating > label {
            position: relative;
            width: 1em;
            font-size: 6vw;
            color: #FFD600;
            cursor: pointer
        }

            .rating > label::before {
                content: "\2605";
                position: absolute;
                opacity: 0
            }

            .rating > label:hover:before,
            .rating > label:hover ~ label:before {
                opacity: 1 !important
            }

        .rating > input:checked ~ label:before {
            opacity: 1
        }

        .rating:hover > input:checked ~ label:before {
            opacity: 0.4
        }



    h1,
    p {
        text-align: center
    }

    h1 {
        margin-top: 150px
    }

    p {
        font-size: 1.2rem
    }

    @@media only screen and (max-width: 600px) {
        h1 {
            font-size: 14px
        }

        p {
            font-size: 12px
        }
    }
</style>
@{

    var yorumlar = ViewBag.BlogYorumlari as List<Restorant_Sitesi.Models.DUYURUBLOGYORUMLARI>;
    int yorumSayisi = yorumlar != null ? yorumlar.Count : 0;
}
@{
    decimal ortalamaPuan = 0;
    decimal toplam = 0;
    Restorant_Sitesi.Models.WRestourantDBEntities db = new Restorant_Sitesi.Models.WRestourantDBEntities();
    if (db.DUYURUBLOGYORUMLARI.Where(x => x.DuyuruID == Model.DuyuruID && x.Durum == true).Count() != 0)
    {
        toplam = Convert.ToDecimal(db.DUYURUBLOGYORUMLARI.Where(x => x.DuyuruID == Model.DuyuruID && x.Durum == true).Sum(x => x.Yildiz));
        ortalamaPuan = Convert.ToDecimal(toplam / db.DUYURUBLOGYORUMLARI.Where(x => x.DuyuruID == Model.DuyuruID && x.Durum == true).Count());
    }

}

@{
    ViewBag.Title = "DUYURULABLOGLARDETAY";
    Layout = "~/Views/Shared/RestourantLayout.cshtml";
}
<section class="hero-wrap hero-wrap-2" style="background-image: url('/images/bg_5.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-end justify-content-center">
            <div class="col-md-9 ftco-animate text-center mb-5">
                <h1 class="mb-2 bread">Blog & Duyuru Detayı</h1>
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Index/Index">Ana Sayfa <i class="fa fa-chevron-right"></i></a></span>
                    <span class="mr-2"><a href="/Index/Bloglar">Blog & Duyuru <i class="fa fa-chevron-right"></i></a></span>
                    <span>Detay <i class="fa fa-chevron-right"></i></span>
                </p>
            </div>
        </div>
    </div>
</section>
<section class="ftco-section">
    <div class="container">
        <div class="row">

            <div class="col-lg-8 ftco-animate">

                <div class="d-flex justify-content-between align-items-baseline mb-3 pb-3 border-bottom">
                    <h2 class="mb-0" style="font-weight: bold; color: #333;">@Html.Raw(@Model.Baslik)</h2>
                    <span style="font-size: 14px; color: #999; font-weight: 500;">
                        <i class="fa fa-user"></i> @Model.Yazar &nbsp;|&nbsp;
                        <i class="fa fa-calendar"></i> @Model.Tarih.Value.ToString("dd.MM.yyyy")
                    </span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4">

                    <!-- SOL: Ortalama puan -->
                    <div class="d-flex align-items-center">
                        <span class="mr-3 font-weight-bold" style="color: #666;">
                            Ortalama Puan: @ortalamaPuan.ToString("0.0")
                        </span>

                        <div class="stars">
                            @if (ortalamaPuan % 1 == 0)
                            {
                                for (int i = 0; i < ortalamaPuan; i++)
                                {
                                    <img src="~/images/doluyıldız.png" width="20" class="mr-1" />
                                }
                                for (int i = 0; i < 5 - ortalamaPuan; i++)
                                {
                                    <img src="~/images/bosyıyldız.png" width="20" class="mr-1" />
                                }
                            }
                            else
                            {
                                int tamKisim = (int)ortalamaPuan;
                                for (int i = 0; i < tamKisim; i++)
                                {
                                    <img src="~/images/doluyıldız.png" width="20" class="mr-1" />
                                }
                                <img src="~/images/yarımyıldız.png" width="20" class="mr-1" />
                                for (int i = 0; i < 4 - tamKisim; i++)
                                {
                                    <img src="~/images/bosyıyldız.png" width="20" class="mr-1" />
                                }
                            }
                        </div>
                    </div>

                    <!-- SAĞ: Görüntülenme -->
                    <div style="font-size: 14px; color: #999;">
                        <i class="fa fa-eye"></i> @Model.Goruntulenme
                    </div>

                </div>
                <p>
                    <img src="../../@Model.Resim" class="img-fluid rounded shadow-sm">
                </p>

                <p style="line-height: 1.8; font-size: 16px; color: #555;">@Html.Raw(@Model.Icerik)</p>



                <!--  BEĞENİ ALANI -->
                <div class="d-flex align-items-center mb-4">

                    <button id="likeBtn" class="btn btn-outline-danger btn-sm">
                        <i class="fa fa-heart"></i> Beğen
                    </button>

                    <span id="likeCount" class="ml-3" style="font-weight: bold;">
                        @Model.Begeni
                    </span>

                </div>

                <div class="pt-5 mt-5 border-top">

                    <h3 class="mb-5 h4 font-weight-bold">@yorumSayisi Yorum</h3>

                    <ul class="comment-list">
                        @if (yorumlar != null && yorumSayisi > 0)
                        {
                            foreach (var yorum in yorumlar.OrderByDescending(x => x.YorumID))
                            {
                                <li class="comment">
                                    <div class="vcard bio">
                                        <img src="/images/person_1.jpg" alt="Kullanıcı" class="rounded-circle shadow-sm">
                                    </div>
                                    <div class="comment-body p-4 bg-light rounded shadow-sm mb-4" style="border-left: 5px solid #d65106;">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <div class="user-info">
                                                <h3 class="mb-1" style="font-size: 18px; color: #d65106; font-weight: bold;">
                                                    @yorum.MusteriAdSoyad
                                                </h3>
                                                <div class="rating-stars">
                                                    @for (int i = 0; i < (yorum.Yildiz ?? 0); i++)
                                                    {
                                                        <img src="~/images/doluyıldız.png" width="18" class="mr-1" alt="Dolu Yıldız" />
                                                    }
                                                    @for (int i = 0; i < 5 - (yorum.Yildiz ?? 0); i++)
                                                    {
                                                        <img src="~/images/bosyıyldız.png" width="18" class="mr-1" alt="Boş Yıldız" />
                                                    }
                                                </div>
                                            </div>

                                            <div class="comment-date">
                                                <span class="text-muted small">
                                                    <i class="fa fa-calendar-o mr-1"></i> @yorum.Tarih.Value.ToString("dd MMMM yyyy, HH:mm")
                                                </span>
                                            </div>
                                        </div>

                                        <div class="comment-text p-2" style="background: #fdfdfd; border-radius: 5px; border-top: 1px solid #eee;">
                                            <p class="mb-0 text-secondary" style="line-height: 1.6; font-style: italic;">
                                                @yorum.YorumMetni
                                            </p>
                                        </div>
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="comment">
                                <div class="comment-body p-4 bg-light rounded text-center">
                                    <p class="text-muted mb-0">Bu yazıya henüz yorum yapılmamış. İlk yorumu siz yapın!</p>
                                </div>
                            </li>
                        }
                    </ul>

                    <div class="comment-form-wrap pt-5">
                        <h3 class="mb-4 h4 font-weight-bold">Bir Yorum Bırakın</h3>

                        <form action="/Index/YorumKaydet" method="post" class="p-4 p-md-5 bg-light rounded shadow-sm">
                            <input type="hidden" name="DuyuruID" value="@Model.DuyuruID" />

                            <div class="rating">
                                <input type="radio" required name="Yildiz" value="5" id="5"><label for="5">☆</label>
                                <input type="radio" required name="Yildiz" value="4" id="4"><label for="4">☆</label>
                                <input type="radio" required name="Yildiz" value="3" id="3"><label for="3">☆</label>
                                <input type="radio" required name="Yildiz" value="2" id="2"><label for="2">☆</label>
                                <input type="radio" required name="Yildiz" value="1" id="1"><label for="1">☆</label>
                            </div>

                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label for="name" class="font-weight-bold">İsim Soyisim *</label>
                                    <input type="text" class="form-control" id="name" name="MusteriAdSoyad" required placeholder="Adınız Soyadınız">
                                </div>
                                <div class="col-md-6 form-group">
                                    <label for="email" class="font-weight-bold">E-posta *</label>
                                    <input type="email" class="form-control" id="email" name="Mail" required placeholder="E-posta Adresiniz">
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="message" class="font-weight-bold">Mesajınız *</label>
                                <textarea name="YorumMetni" id="message" cols="30" rows="5" class="form-control" required placeholder="Düşüncelerinizi buraya yazın..."></textarea>
                            </div>

                            <div class="form-group p-3 mb-4" style="background-color: #fff3cd; border-left: 5px solid #ffecb5; border-radius: 4px;">
                                <label for="securityCode" class="font-weight-bold text-dark mb-1">
                                    Güvenlik Doğrulaması <span class="text-danger">*</span>
                                </label>

                                <p class="text-muted small mb-2">Lütfen aşağıdaki kelimeyi kutucuğa yazınız: <strong class="text-danger" style="font-size:16px; letter-spacing: 2px;">@ViewBag.GosterilenKod</strong></p>

                                <input type="text" class="form-control" id="securityCode" name="GirilenDogrulamaKodu" required placeholder="Kelimeyi giriniz" autocomplete="off" style="text-transform: uppercase;"
                                       oninput="this.value = this.value.toUpperCase();">
                            </div>

                            <div class="form-group mb-0">
                                <button type="submit" class="btn btn-primary py-3 px-5 shadow-sm" style="border-radius: 30px;">
                                    <i class="fa fa-paper-plane mr-2"></i> Yorumu Gönder
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            </div> <div class="col-lg-4 sidebar ftco-animate pl-lg-5">
                <div class="sidebar-box mt-4 mt-lg-0">

                </div>

                <div class="sidebar-box ftco-animate">
                    <h3 class="heading-sidebar">Kategoriler</h3>
                    <ul class="categories">
                        <li><a href="#">Kahvaltı <span>(6)</span></a></li>
                        <li><a href="#">Öğle Yemeği <span>(8)</span></a></li>
                        <li><a href="#">Akşam Yemeği <span>(2)</span></a></li>
                        <li><a href="#">Tatlılar <span>(2)</span></a></li>
                    </ul>
                </div>

                <div class="sidebar-box ftco-animate">
                    <h3 class="heading-sidebar">Popüler Yazılar</h3>
                    @{
                        var onerilenler = ViewBag.PopulerYazilar as List<Restorant_Sitesi.Models.DUYURULABLOGLAR>;
                    }
                    @if (onerilenler != null)
                    {
                        foreach (var x in onerilenler)
                        {
                            <div class="block-21 mb-4 d-flex">
                                <a class="blog-img mr-4" style="background-image: url('../../@x.Resim'); border-radius: 5px;"></a>
                                <div class="text">
                                    <h3 class="heading"><a href="/Index/DUYURULABLOGLARDETAY/@x.DuyuruID">@Html.Raw(x.Icerik)</a></h3>
                                    <div class="meta">
                                        <div><a href="#"><span class="icon-calendar"></span> @x.Tarih.Value.ToString("dd.MM.yyyy")</a></div>
                                        <div><a href="#"><span class="icon-person"></span> @x.Yazar</a></div>
                                    </div>
                                </div>
                            </div>

                        }

                    }
                </div>


                <div class="sidebar-box ftco-animate">
                    <h3 class="heading-sidebar">Hakkımızda</h3>
                    <p>Lezzet yolculuğumuzu ve restoranımızdaki en özel anları sizinle paylaşıyoruz.</p>
                </div>

            </div>
        </div>
    </div>
</section>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function () {

    $("#likeBtn").click(function () {

        $.ajax({
            url: "/Index/BegeniArttir",
            type: "POST",
            data: { id: @Model.DuyuruID },
            success: function (res) {

                if (res.success) {
                    $("#likeCount").text(res.begeni);

                    // ❤️ Buton değişsin
                    $("#likeBtn")
                        .addClass("btn-danger")
                        .removeClass("btn-outline-danger")
                        .html('<i class="fa fa-heart"></i> Beğenildi')
                        .prop("disabled", true);
                }
                else {
                    alert(res.message);

                    // Zaten beğendiyse disable et
                    $("#likeBtn").prop("disabled", true);
                }
            }
        });

    });

});
</script>