@model Restorant_Sitesi.Models.UYELER
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="ADAM olun" />
    <meta name="author" content="Gamaci" />
    <title>Moly- RS Kayıt Ol</title>
    <!-- loader-->
    <link href="~/AdminTemplate/assets/css/pace.min.css" rel="stylesheet" />
    <script src="~/AdminTemplate/assets/js/pace.min.js"></script>
    <!--favicon-->
    <link rel="icon" href="~/AdminTemplate/assets/images/favicon.ico" type="image/x-icon">
    <!-- Bootstrap core CSS-->
    <link href="~/AdminTemplate/assets/css/bootstrap.min.css" rel="stylesheet" />
    <!-- animate CSS-->
    <link href="~/AdminTemplate/assets/css/animate.css" rel="stylesheet" type="text/css" />
    <!-- Icons CSS-->
    <link href="~/AdminTemplate/assets/css/icons.css" rel="stylesheet" type="text/css" />
    <!-- Custom Style-->
    <link href="~/AdminTemplate/assets/css/app-style.css" rel="stylesheet" />

    <style>
        /* CSS Artık Head İçinde ve !important ile Ezilmeleri Önledik */
        .custom-select-themed {
            font-family: inherit !important;
            font-size: 14px !important;
            background-color: rgba(255, 255, 255, 0.2) !important;
            color: rgba(255, 255, 255, 0.7) !important;
            border: 1px solid rgba(255, 255, 255, 0.15) !important;
            border-radius: 4px;
            height: 38px !important; /* Diğer inputlarla aynı yükseklik */
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
        }

            .custom-select-themed option {
                background-color: #2b3a4a !important;
                color: #fff !important;
            }

        .has-icon-right .custom-select-themed {
            padding-right: 40px !important;
        }

        /* Input placeholder renk uyumu */
        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.5) !important;
        }
        #wrapper {
            min-height: 100vh; /* Ekranın tam yüksekliğini al */
            display: flex; /* Esnek kutu yapısını aç */
            align-items: center; /* Dikeyde ortala */
            justify-content: center; /* Yatayda ortala */
        }

        /* Kartın dışındaki fazlalık boşluğu sıfırlayalım ki tam merkezde kalsın */
        .card-authentication1 {
            margin: 0 !important;
            width: 100%; /* Mobilde düzgün durması için */
            max-width: 450px; /* Panel çok yayılmasın */
        }
    </style>
</head>
<body class="bg-theme bg-theme1">

    <div id="pageloader-overlay" class="visible incoming">
        <div class="loader-wrapper-outer">
            <div class="loader-wrapper-inner"><div class="loader"></div></div>
        </div>
    </div>

    <div id="wrapper">
        <div class="card card-authentication1 mx-auto my-4">
            <div class="card-body">
                <div class="card-content p-2">
                    <div class="text-center">
                        <img src="~/images/logo.png" height="100" width="100" alt="logo icon">
                    </div>
                    <div class="card-title text-uppercase text-center py-3">Kayıt Ol</div>

                    @using (Html.BeginForm("KayitOl", "Index", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label class="sr-only">Ad Soyad</label>
                            <div class="position-relative has-icon-right">
                                @Html.TextBoxFor(x => x.AdSoyad, new { @class = "form-control input-shadow", placeholder = "Adınızı ve Soyadınızı Giriniz", required = "required" })
                                <div class="form-control-position"><i class="icon-user"></i></div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="sr-only">E-posta</label>
                            <div class="position-relative has-icon-right">
                                @Html.TextBoxFor(x => x.Mail, new { @class = "form-control input-shadow", type = "email", placeholder = "E-posta Adresiniz", required = "required" })
                                <div class="form-control-position"><i class="icon-envelope-open"></i></div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="sr-only">Şifre</label>
                            <div class="position-relative has-icon-right">
                                @Html.PasswordFor(x => x.Sifre, new { @id = "pass-input", @class = "form-control input-shadow", placeholder = "Şifre Seçiniz", required = "required" })
                                <div class="form-control-position" style="cursor: pointer;" id="toggle-password">
                                    <i class="fa fa-eye" id="eye-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="sr-only">Cinsiyet Seçin</label>
                            <div class="position-relative has-icon-right">
                                <select class="form-control input-shadow custom-select-themed" name="Cinsiyet" id="cinsiyet" required>
                                    <option value="" selected disabled>Cinsiyet Seçin...</option>
                                    <option value="Erkek">Erkek</option>
                                    <option value="Kadın">Kadın</option>
                                </select>
                                <div class="form-control-position"><i class="icon-user"></i></div>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="icheck-material-white">
                                <input type="checkbox" id="user-checkbox" checked required />
                                <label for="user-checkbox">
                                    <a href="javascript:void();" data-toggle="modal" data-target="#termsModal" style="text-decoration: underline; color: #fff;">
                                        Şartları ve Koşulları
                                    </a> Kabul Ediyorum
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-light btn-block waves-effect waves-light">Kayıt Ol</button>
                    }

                    <div class="form-row mt-4">
                        <div class="form-group mb-0 col-6">
                            <button type="button" class="btn btn-light btn-block"><i class="fa fa-facebook-square"></i> Facebook</button>
                        </div>
                        <div class="form-group mb-0 col-6 text-right">
                            <button type="button" class="btn btn-light btn-block"><i class="fa fa-twitter-square"></i> Twitter</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer text-center py-3">
                <p class="text-warning mb-0">Zaten bir hesabınız var mı? <a href="/Index/Girisyap"> Giriş Yap</a></p>
            </div>
        </div>
    </div>

    <script src="~/AdminTemplate/assets/js/jquery.min.js"></script>
    <script src="~/AdminTemplate/assets/js/popper.min.js"></script>
    <script src="~/AdminTemplate/assets/js/bootstrap.min.js"></script>

    <!-- sidebar-menu js -->
    <script src="~/AdminTemplate/assets/js/sidebar-menu.js"></script>

    <!-- Custom scripts -->
    <script src="~/AdminTemplate/assets/js/app-script.js"></script>

    <style>
        .custom-select-themed {
            /* Yazı fontunun diğer inputlarla aynı olması için */
            font-family: inherit;
            font-size: 14px; /* Veya temanızın standart font boyutu */

            background-color: rgba(255, 255, 255, 0.2) !important;
            color: rgba(255, 255, 255, 0.7) !important; /* Placeholder rengine yaklaştırmak için */
            border: 1px solid rgba(255, 255, 255, 0.15) !important;
            border-radius: 4px;
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
        }

            /* Seçeneklerin (dropdown açıldığında) okunabilir olması için */
            .custom-select-themed option {
                background-color: #2b3a4a; /* Temanın koyu tonlarına uygun bir renk */
                color: #fff;
            }

        /* İkonun select yazısının üstüne binmemesi için */
        .has-icon-right .custom-select-themed {
            padding-right: 40px;
        }
    </style>

    <script>
        $(document).ready(function () {
            $("#toggle-password").click(function () {
                var input = $("#pass-input");
                var icon = $("#eye-icon");

                if (input.attr("type") === "password") {
                    input.attr("type", "text");
                    // Gözü "üzeri çizili göz" yap (isteğe bağlı)
                    icon.removeClass("fa-eye").addClass("fa-eye-slash");
                } else {
                    input.attr("type", "password");
                    // Tekrar normal göz yap
                    icon.removeClass("fa-eye-slash").addClass("fa-eye");
                }
            });
        });
    </script>

    <div class="modal fade" id="termsModal" tabindex="-1" role="dialog" aria-labelledby="termsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content bg-dark border-light">
                <div class="modal-header border-light">
                    <h5 class="modal-title text-white" id="termsModalLabel">Kullanım Şartları ve Koşullar</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body text-white" style="max-height: 400px; overflow-y: auto;">
                    <p>1. Moly RS platformumuza hoş geldiniz.</p>
                    <p>2. Kişisel verileriniz KVKK kapsamında korunmaktadır.</p>
                    <p>3. Kayıt olduğunuzda e-posta bültenimize katılmayı kabul etmiş sayılırsınız.</p>
                    <p>4. Sisteme verilen bilgilerin doğruluğundan kullanıcı sorumludur.</p>
                    <hr>
                    <p>Bu alan restoran otomasyon sistemimizin kullanım kurallarını içerir...</p>
                </div>
                <div class="modal-footer border-light">
                    <button type="button" class="btn btn-light" data-dismiss="modal">Kapat</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>