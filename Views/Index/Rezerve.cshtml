
@{
    ViewBag.Title = "Rezerve";
    Layout = "~/Views/Shared/RestourantLayout.cshtml";
}
<style>
    /* Arka plan */
    .reservation-bg {
        background: linear-gradient(135deg, #0f5132, #198754);
        min-height: 100vh;
    }

    /* Kart tasarımı */
    .reservation-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        color: white;
    }

    /* Başlık */
    .reservation-title {
        font-weight: 600;
        margin-bottom: 25px;
    }

    /* Inputlar */
    .form-control {
        border-radius: 10px;
    }

    /* Buton */
    .btn-reserve {
        background: #ffc107;
        border: none;
        color: black;
        font-weight: 600;
        border-radius: 10px;
        transition: 0.3s;
    }

        .btn-reserve:hover {
            background: #ffca2c;
            transform: scale(1.03);
        }
</style>
<section class="hero-wrap hero-wrap-2" style="background-image: url('/images/bg_5.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-end justify-content-center">
            <div class="col-md-9 ftco-animate text-center mb-5">
                <h1 class="mb-2 bread"> Rezervasyonlar </h1>
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Index/Index">Ana Sayfa <i class="fa fa-chevron-right"></i></a></span>
                    <span>Rezervasyonlar<i class="fa fa-chevron-right"></i></span>
                </p>
            </div>
        </div>
    </div>
</section>
<section class="ftco-section ftco-no-pb ftco-no-pt reservation-bg">
    <div class="container-fluid p-0">
        <div class="row no-gutters justify-content-center align-items-center min-vh-100">

            <div class="col-md-4">
                <div class="reservation-card">

                    <h2 class="reservation-title text-center">Rezervasyon Yapın</h2>

                    <form action="/Index/RezarvasyonYap" method="post">

                        <div class="form-floating mb-3">
                            <label>Ad Soyad</label>
                            <input type="text" name="MusteriAdSoyad" class="form-control" placeholder="Ad Soyad" required>
                        </div>

                        <div class="form-floating mb-3">
                            <label>Mail Adresi</label>
                            <input type="email" name="Mail" class="form-control" placeholder="Mail" required>
                        </div>

                        <div class="form-floating mb-3">
                            <label>Telefon</label>
                            <input type="tel" name="MusteriTelefon" class="form-control" placeholder="Telefon" required>
                        </div>

                        <div class="row">
                            <div class="col">
                                <div class="form-floating mb-3">
                                    <label>Tarih</label>
                                    <!-- JS için id="dateInput" eklendi ve type="date" yapıldı -->
                                    <input type="date" id="dateInput" name="Tarih" class="form-control" required>
                                </div>
                            </div>

                            <div class="col">
                                <div class="form-floating mb-3">
                                    <label>Saat</label>
                                    <!-- JS'nin içini doldurabilmesi için input yerine select kullanmalısın -->
                                    <select id="timeInput" name="Saat" class="form-control" required>
                                        <option value="">Seçiniz</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <label>Kişi Sayısı</label>
                            <input type="number" name="KisiSayisi" class="form-control" placeholder="Kişi Sayısı (Örn: 4)" min="1" required>
                        </div>
                        <button type="submit" class="btn btn-reserve w-100">Masayı Ayırt</button>
                    </form>

                </div>
            </div>

        </div>
    </div>
</section>
<script>
    const workingHours = {
        1: { open: "09:00", close: "24:00" },
        2: { open: "09:00", close: "24:00" },
        3: { open: "09:00", close: "24:00" },
        4: { open: "09:00", close: "24:00" },
        5: { open: "09:00", close: "26:00" }, // 02:00 için 26:00 mantığı (ertesi gün)
        6: { open: "09:00", close: "26:00" },
        0: { open: "10:00", close: "22:00" }  // Pazar gününü boş bırakma, bir saat ata
    };

    const dateInput = document.getElementById("dateInput");
    const timeInput = document.getElementById("timeInput");

    // Bugünün tarihinden öncesini seçtirme
    dateInput.min = new Date().toISOString().split("T")[0];

    function generateTimes(open, close) {
        const times = [];
        let start = parseInt(open.split(":")[0]) * 60 + parseInt(open.split(":")[1]);
        let end = parseInt(close.split(":")[0]) * 60 + parseInt(close.split(":")[1]);

        for (let t = start; t < end; t += 30) {
            let h = Math.floor(t / 60);
            let realH = h >= 24 ? h - 24 : h; // 24'ten sonrasını 00, 01 diye düzeltir
            let m = String(t % 60).padStart(2, "0");
            times.push(`${String(realH).padStart(2, "0")}:${m}`);
        }
        return times;
    }

    dateInput.addEventListener("change", function () {
        if (!this.value) return;

        const selectedDate = new Date(this.value);
        const day = selectedDate.getDay();
        const now = new Date();

        timeInput.innerHTML = '<option value="">Seçiniz</option>';

        const config = workingHours[day];
        if (!config) {
            timeInput.disabled = true;
            return;
        }

        timeInput.disabled = false;
        const times = generateTimes(config.open, config.close);

        const isToday = selectedDate.toDateString() === now.toDateString();
        const currentMinutes = now.getHours() * 60 + now.getMinutes();

        times.forEach(t => {
            let [h, m] = t.split(":").map(Number);
            let minutes = h * 60 + m;
            // Eğer saat 00, 01 ise ve dükkan hala açıksa (gece saatleri)
            if (h < 5) minutes += 1440;

            const option = document.createElement("option");
            option.value = t;
            option.textContent = t;

            // Geçmiş saatleri engelle (Sadece bugün için)
            if (isToday && minutes < currentMinutes + 30) {
                option.disabled = true;
            }
            timeInput.appendChild(option);
        });
    });
</script>
