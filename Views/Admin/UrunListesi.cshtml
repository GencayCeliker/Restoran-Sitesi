@model List<Restorant_Sitesi.Models.URUNLER>
@{
    ViewBag.Title = "Ürün Yönetimi";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark font-weight-bold mb-0">Menü & Ürün Yönetimi</h2>
            <p class="text-muted">Restoran menüsündeki ürünleri buradan yönetebilirsiniz.</p>
        </div>
        <a href="/Admin/UrunEkle" class="btn btn-primary btn-round px-4 shadow-sm">
            <i class="fa fa-plus-circle mr-1"></i> Yeni Ürün Ekle
        </a>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-body p-0">
            @* Kenar boşluklarını sıfırlayıp tabloyu yaydık *@
            <div class="table-responsive">
                <table class="table table-hover align-items-center mb-0" id="urunTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-center" style="width: 50px;">ID</th>
                            <th>Ürün Bilgisi</th>
                            <th>Kategori</th>
                            <th class="text-center">Fiyat</th>
                            <th class="text-center">Durum</th>
                            <th class="text-center" style="width: 200px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td class="text-center text-muted">#@x.UrunID</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="mr-3">
                                            @if (!string.IsNullOrEmpty(x.Resim))
                                            {
                                                <img src="@x.Resim" class="rounded-circle shadow-sm" width="50" height="50" style="object-fit: cover; border: 2px solid #fff;">
                                            }
                                            else
                                            {
                                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white shadow-sm" width="50" height="50" style="width:50px; height:50px;">
                                                    <i class="fa fa-image"></i>
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <span class="d-block font-weight-bold text-dark">@x.UrunAd</span>
                                            <small class="text-muted">@(x.Icindekiler?.Length > 30 ? x.Icindekiler.Substring(0, 30) + "..." : x.Icindekiler)</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-light p-2 border">
                                        <i class="fa fa-tag mr-1"></i> @(x.KATEGORILER?.KategoriAd ?? "Belirtilmedi")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="text-primary font-weight-bold" style="font-size: 16px;">
                                        @string.Format("{0:C2}", x.Fiyat)
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (x.Durum == true)
                                    {
                                        <span class="badge badge-success badge-pill px-3 py-2">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger badge-pill px-3 py-2">Pasif</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="/Admin/UrunGuncelle/@x.UrunID" class="btn btn-outline-success btn-sm border-0 mr-1" title="Düzenle">
                                        <i class="fa fa-pencil fa-lg"></i>
                                    </a>
                                    <a href="/Admin/UrunSil/@x.UrunID" class="btn btn-outline-danger btn-sm border-0 deleteBtn" title="Sil">
                                        <i class="fa fa-trash-o fa-lg"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.deleteBtn').on('click', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');

                Swal.fire({
                    title: '<span style="color: #ff0000; font-weight:bold;">Emin misiniz?</span>',
                    text: "Bu ürünü menüden kalıcı olarak silmek istediğinize emin misiniz?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                    confirmButtonText: "Evet, sil!",
                    cancelButtonText: "İptal",
                    background: '#fff',
                    backdrop: `rgba(0,0,0,0.4)`
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            });
        });
    </script>
}
