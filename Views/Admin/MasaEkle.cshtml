
@{
    ViewBag.Title = "MasaEkle";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<style>

    /* Kart görünümü */
    .admin-card {
        background: linear-gradient(145deg, #1e1e2f, #2a2a40);
        border-radius: 15px;
        color: white;
    }

    /* Inputlar */
    .custom-input {
        background-color: #2c2c3e;
        border: 1px solid #444;
        color: white;
        border-radius: 10px;
    }

        .custom-input:focus {
            border-color: #ffc107;
            box-shadow: 0 0 10px rgba(255,193,7,0.5);
        }

    /* Floating label fix */
    .form-floating > label {
        color: #aaa;
    }

    /* Hover efekt */
    .btn-success {
        transition: 0.3s;
    }

        .btn-success:hover {
            transform: scale(1.05);
        }

    /* Card hover efekti */
    .admin-card:hover {
        transform: translateY(-3px);
        transition: 0.3s;
    }
</style>
<br />
<br />
<div class="card shadow-lg border-0 admin-card">
    <div class="card-body p-4">

        <h4 class="mb-4 text-warning">
            <i class="fa fa-plus-circle me-2"></i> Yeni Masa Ekle
        </h4>

        <form method="post">

            <div class="form-floating mb-3">
                <input type="number" name="MasaNo" class="form-control custom-input" placeholder="Masa No" required />
                <label>Masa Numarası</label>
            </div>

            <div class="form-floating mb-4">
                <input type="number" name="Kapasite" class="form-control custom-input" placeholder="Kapasite" required />
                <label>Kapasite (Kişi Sayısı)</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success w-100">
                    <i class="fa fa-save me-1"></i> Kaydet
                </button>

                <a href="/Admin/Masalar" class="btn btn-outline-light w-100">
                    Vazgeç
                </a>
            </div>

        </form>
    </div>
</div>

