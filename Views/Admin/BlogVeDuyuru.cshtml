@using Restorant_Sitesi.Models
@model Tuple<List<DUYURULABLOGLAR>, List<DUYURUBLOGYORUMLARI>>

@{
    ViewBag.Title = "Blog & Duyuru Yönetimi";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<br />
<br />
<h3>Blog & Duyuru Yönetim</h3>
<br />
<br />


<div class="row">
    <div class="col-lg-7">
        <div class="card shadow mb-4" style="background: rgba(0, 0, 0, 0.2); border: none; color: white;">
            <div class="card-header py-3" style="background: transparent; border-bottom: 1px solid rgba(255,255,255,0.1);">
                <h6 class="m-0 font-weight-bold" style="color: #e0e0e0;">Blog ve Duyuru Listesi</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table text-white mb-0">
                        <thead style="background: rgba(0, 0, 0, 0.4);">
                            <tr style="text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">
                                <th class="text-center">Resim</th>
                                <th>Başlık</th>
                                <th class="text-center">Tarih</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model.Item1)
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="@x.Resim" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;" />
                                    </td>
                                    <td class="text-truncate" style="max-width: 150px;">@x.Baslik</td>
                                    <td class="text-center">@(x.Tarih.HasValue ? x.Tarih.Value.ToString("dd.MM.yyyy") : "-")</td>
                                    <td class="text-center">
                                        <span class="badge @(x.Durum == true ? "badge-success" : "badge-danger")">
                                            @(x.Durum == true ? "AKTİF" : "PASİF")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-info" onclick="blogDuzenle(@x.DuyuruID)">DÜZENLE</button>
                                        <a href="/Admin/BlogSil/@x.DuyuruID" class="btn btn-sm btn-danger" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?')">SİL</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5" id="formArea">
        <div class="card shadow mb-4" style="background: rgba(0, 0, 0, 0.2); border: none; color: white;">
            <div class="card-header py-3" style="background: transparent; border-bottom: 1px solid rgba(255,255,255,0.1);">
                <h6 class="m-0 font-weight-bold" style="color: #e0e0e0;">Blog Ekle / Güncelle</h6>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("BlogKaydet", "Admin", FormMethod.Post, new { enctype = "multipart/form-data", id = "blogForm" }))
                {
                    <input type="hidden" name="DuyuruID" id="DuyuruID" value="0" />

                    <div class="form-group">
                        <label>BAŞLIK</label>
                        <textarea name="Baslik" id="Baslik" class="summernote-kisa" required></textarea>
                    </div>

                    <div class="form-group">
                        <label>YAZAR</label>
                        <input type="text" name="Yazar" id="Yazar" class="form-control" style="background: rgba(255,255,255,0.1); border: none; color: white;" required />
                    </div>

                    <div class="form-group">
                        <label>İÇERİK (DETAY)</label>
                        <textarea name="Icerik" id="summernote" class="summernote"></textarea>
                    </div>

                    <div class="form-group">
                        <label>RESİM YÜKLE</label>
                        <input type="file" name="resimDosyasi" class="form-control" onchange="$('#onizleme').show(); $('#onizlemeImg')[0].src = window.URL.createObjectURL(this.files[0])" />
                        <div id="onizleme" style="display:none;" class="mt-2 text-center">
                            <img id="onizlemeImg" class="rounded shadow" style="max-height: 120px; width: 100%; object-fit: cover;" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>YAYIN DURUMU</label>
                        <select name="Durum" id="Durum" class="form-control" style="background: rgba(255,255,255,0.1); border: none; color: #ccc;">
                            <option value="true">Aktif (Sitede Görünsün)</option>
                            <option value="false">Pasif (Gizle)</option>
                        </select>
                    </div>

                    <button type="submit" id="submitBtn" class="btn btn-primary btn-block">DEĞİŞİKLİKLERİ KAYDET</button>
                    <button type="button" class="btn btn-secondary btn-block mt-2" onclick="formuTemizle()">İPTAL / YENİ KAYIT</button>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow mb-4" style="background: rgba(0, 0, 0, 0.2); border: none; color: white;">
            <div class="card-header py-3" style="background: transparent; border-bottom: 1px solid rgba(255,255,255,0.1);">
                <h6 class="m-0 font-weight-bold" style="color: #e0e0e0;">Yorum Yönetimi</h6>
            </div>
            <div class="table-responsive">
                <table class="table text-white mb-0">
                    <thead>
                        <tr>
                            <th>Ad Soyad</th>
                            <th>Mail</th>
                            <th>Blog</th>
                            <th>Durum</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var y in Model.Item2)
                        {
                            <tr>
                                <td>@y.MusteriAdSoyad</td>
                                <td>@y.Mail</td>
                                <td>@y.DUYURULABLOGLAR.Baslik</td>
                                <td>
                                    <span class="badge @(y.Durum == true ? "badge-success" : "badge-warning")">
                                        @(y.Durum == true ? "Yayında" : "Onay Bekliyor")
                                    </span>
                                </td>
                                <td>
                                    @if (y.Durum == false)
                                    {
                                        <a href="/Admin/BlogYorumOnayla/@y.YorumID" class="btn btn-sm btn-success">Yayınla</a>
                                    }
                                    else
                                    {
                                        <a href="/Admin/BlogYorumKaldir/@y.YorumID" class="btn btn-sm btn-warning">Kaldır</a>
                                    }
                                    <a href="/Admin/BlogYorumSil/@y.YorumID" class="btn btn-sm btn-danger" onclick="return confirm('Yorumu silmek istediğinize emin misiniz?')">Sil</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function blogDuzenle(id) {
            $.ajax({
                url: '/Admin/BlogGetir/' + id,
                type: 'POST',
                success: function (data) {
                    if (data != null) {
                        $('#DuyuruID').val(data.id);
                        $('#Yazar').val(data.yazar);

                        // Summernote içeriklerini doldur
                        $('#Baslik').summernote('code', data.baslik || '');
                        $('#summernote').summernote('code', data.icerik || '');

                        $('#Durum').val(data.durum.toString().toLowerCase());

                        if (data.resim) {
                         
                            var resimYolu = data.resim.startsWith('/') ? data.resim : '/' + data.resim;
                            $('#onizlemeImg').attr('src', resimYolu);
                            $('#onizleme').fadeIn();
                        }

                        $('#submitBtn').text("GÜNCELLEMEYİ KAYDET").removeClass("btn-primary").addClass("btn-warning");
                        $('html, body').animate({ scrollTop: $("#formArea").offset().top - 20 }, 800);
                    }
                },
                error: function () {
                    toastr.error('Blog verisi alınamadı!');
                }
            });
        }

        function formuTemizle() {
            $('#DuyuruID').val(0);
            $('#blogForm')[0].reset();

            // Summernote'ları temizle
            $('#Baslik').summernote('code', '');
            $('#summernote').summernote('code', '');

            $('#onizleme').fadeOut();
            $('#submitBtn').text("DEĞİŞİKLİKLERİ KAYDET").removeClass("btn-warning").addClass("btn-primary");
            $('html, body').animate({ scrollTop: 0 }, 600);
        }
    </script>
}