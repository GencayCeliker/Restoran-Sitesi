<style>
    .table td, .table th {
        border-top: 0 !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        padding-top: 0.5rem !important;
        padding-bottom: 0.5rem !important;
        vertical-align: middle !important;
    }

    .table thead th {
        border-bottom-width: 1px !important;
        padding-bottom: 10px !important;
    }

    .table img {
        margin: 0 !important;
        display: block;
    }

    .card-body {
        padding-top: 10px !important;
    }
</style>

@model IEnumerable<Restorant_Sitesi.Models.ANASAYFA>
@{
    ViewBag.Title = "SliderYonetimi";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="row mb-4">
    <div class="col-lg-12">
        <div class="card bg-dark">
            <div class="card-header">Canlı Slider Önizlemesi</div>
            <div class="card-body">
                <div id="sliderPreview" class="carousel slide" data-ride="carousel">
                    <div class="carousel-inner" style="height: 250px;">
                        @{ int i = 0; }
                        @foreach (var x in Model)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@x.Resim" class="d-block w-100" style="object-fit: cover; height: 250px; opacity:0.6">
                                <div class="carousel-caption d-none d-md-block">
                                    <h5>@x.Baslik</h5>
                                    <p>@x.Icerik</p>
                                    <p>@Html.Raw(x.Aciklama)</p>
                                </div>
                            </div>
                            i++;
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">Mevcut Kayıtlar</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Resim</th>
                                <th>Başlık</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model)
                            {
                                <tr>
                                    <td><img src="@x.Resim" width="60" class="rounded" /></td>
                                    <td>@x.Baslik</td>
                                    <td>
                                        <span class="badge @(x.Durum ? "badge-success" : "badge-danger")">
                                            @(x.Durum ? "Aktif" : "Pasif")
                                        </span>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-info" onclick="sliderDuzenle(@x.AnasayfaID)">
                                            DÜZENLE
                                        </button>
                                        <a href="/Admin/SliderSil/@x.AnasayfaID" class="btn btn-sm btn-danger" onclick="return confirm('Bu slider kaydını silmek istediğinize emin misiniz? (Resim dosyanız silinmeyecektir)')">
                                            SİL
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Slider Ekle / Güncelle</div>
            <div class="card-body">
                @using (Html.BeginForm("SliderKaydet", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    <input type="hidden" name="EskiResimYolu" id="EskiResimYolu" />
                    <input type="hidden" name="AnasayfaID" id="AnasayfaID" value="0" />
                    <div class="form-group">
                        <label>Başlık</label>
                        <input type="text" name="Baslik" class="form-control" placeholder="Ana başlık..." required />
                    </div>
                    <div class="form-group">
                        <label>İçerik</label>
                        <input type="text" name="Icerik" class="form-control" placeholder="Kısa içerik yazısı..." required />
                    </div>
                    <div class="form-group">
                        <label>Açıklama (Detay)</label>
                        <textarea name="Aciklama" id="summernote" class="form-control summernote"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Resim Yükle</label>
                        <input type="file" name="ResimDosyasi" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Yayın Durumu</label>
                        <select name="Durum" class="form-control">
                            <option value="true">Aktif (Sitede Görünsün)</option>
                            <option value="false">Pasif (Gizle)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Yeni Slider Ekle</button>
                    <button type="button" class="btn btn-secondary btn-block mt-2" onclick="formuTemizle()">İptal / Yeni Kayıt</button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function sliderDuzenle(id) {
            // Arka planda Controller'daki metoda gidip veriyi istiyoruz
            $.ajax({
                url: '/Admin/SliderGuncelle',
                type: 'POST',
                data: { id: id },
                success: function (data) {
                    if (data != null) {
                        $('#AnasayfaID').val(id);
                        $('#EskiResimYolu').val(data.resim);
                        $('input[name="Baslik"]').val(data.baslik);
                        $('input[name="Icerik"]').val(data.icerik);

                        var durum = (data.durum === true || data.durum === "True" || data.durum === "true") ? "true" : "false";
                        $('select[name="Durum"]').val(durum);

                        var aciklamaMetni = data.aciklama ? data.aciklama : "";
                        $('#summernote').summernote('code', aciklamaMetni);

                        $('.btn-block').first().text("GÜNCELLE").removeClass("btn-primary").addClass("btn-warning");

                        $('html, body').animate({
                            scrollTop: $(".col-lg-5").offset().top - 100
                        }, 500);
                    }
                },
                error: function () {
                    alert("Veri çekilirken bir hata oluştu!");
                }
            });
        }

        function formuTemizle() {
            $('#AnasayfaID').val(0);
            $('#EskiResimYolu').val('');
            $('form')[0].reset();
            $('#summernote').summernote('code', ''); // Editörü temizler
            $('.btn-block').first().text("Değişiklikleri Kaydet").removeClass("btn-warning").addClass("btn-primary");
        }
    </script>
}