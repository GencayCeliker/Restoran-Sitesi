<style>
    .table td, .table th {
        border-top: 0 !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        padding-top: 0.5rem !important;
        padding-bottom: 0.5rem !important;
        vertical-align: middle !important;
    }

    .table thead th {
        border-bottom-width: 1px !important;
        padding-bottom: 10px !important;
    }

    .table img {
        margin: 0 !important;
        display: block;
    }

    .card-body {
        padding-top: 10px !important;
    }
    /* Summernote stabilizasyonu */
    .note-editor {
        transition: none !important; /* Animasyonları kapat */
        transform: translateZ(0); /* GPU ivmesi */
        backface-visibility: hidden;
        -webkit-font-smoothing: antialiased;
    }

    .note-editable {
        min-height: 100px;
        overflow-y: auto !important;
    }
</style>
@model IEnumerable<Restorant_Sitesi.Models.ANASAYFA>
@{
    ViewBag.Title = "SliderYonetimi";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<div class="row mb-4">
    <div class="col-lg-12">
        <div class="card bg-dark">
            <div class="card-header">Canlı Slider Önizlemesi</div>
            <div class="card-body">
                <div id="sliderPreview" class="carousel slide" data-ride="carousel">
                    <div class="carousel-inner" style="height: 250px;">
                        @{ int i = 0; }
                        @foreach (var x in Model)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@x.Resim" class="d-block w-100" style="object-fit: cover; height: 250px; opacity:0.6">
                                <div class="carousel-caption d-none d-md-block">
                                    <h5>@Html.Raw(x.Baslik)</h5>
                                    <p>@Html.Raw(x.Icerik)</p>
                                    <p>@Html.Raw(x.Aciklama)</p>
                                </div>
                            </div>
                            i++;
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">Mevcut Kayıtlar</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Resim</th>
                                <th>Başlık</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model)
                            {
                                <tr>
                                    <td><img src="@x.Resim" width="60" class="rounded" /></td>
                                    <td>@Html.Raw(x.Baslik)</td>
                                    <td>
                                        <span class="badge @(x.Durum ? "badge-success" : "badge-danger")">@(x.Durum ? "Aktif" : "Pasif")</span>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-info" onclick="sliderDuzenle(@x.AnasayfaID)">DÜZENLE</button>
                                        <a href="/Admin/SliderSil/@x.AnasayfaID" class="btn btn-sm btn-danger" onclick="return confirm('Bu slider kaydını kalıcı olarak silmek istediğinize emin misiniz?')">SİL</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Slider Ekle / Güncelle</div>
            <div class="card-body">
                @using (Html.BeginForm("SliderKaydet", "Admin", FormMethod.Post, new { enctype = "multipart/form-data", id = "sliderForm" }))
                {
                    <input type="hidden" name="EskiResimYolu" id="EskiResimYolu" />
                    <input type="hidden" name="AnasayfaID" id="AnasayfaID" value="0" />
                    <div class="form-group">
                        <label>Başlık</label>
                        <textarea name="Baslik" id="Baslik" class="form-control summernote-kisa"></textarea>
                    </div>
                    <div class="form-group">
                        <label>İçerik</label>
                        <textarea name="Icerik" id="Icerik" class="form-control summernote-kisa"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Açıklama (Detay)</label>
                        <textarea name="Aciklama" id="summernote" class="form-control summernote"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Resim Yükle</label>
                        <input type="file" name="ResimDosyasi" class="form-control" onchange="$('#onizlemeKutusu').show(); $('#canliResim')[0].src = window.URL.createObjectURL(this.files[0])" />

                        <div id="onizlemeKutusu" style="display:none;" class="mt-3 text-center">
                            <span class="badge badge-info mb-1">Yeni Seçilen Resim</span>
                            <img id="canliResim" style="width:100%; height:150px; object-fit:cover; border-radius:8px; border:2px dashed #00a8ff;" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Yayın Durumu</label>
                        <select name="Durum" id="Durum" class="form-control">
                            <option value="true">Aktif (Sitede Görünsün)</option>
                            <option value="false">Pasif (Gizle)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Değişiklikleri Kaydet</button>
                    <button type="button" class="btn btn-secondary btn-block mt-2" onclick="formuTemizle()">İptal / Yeni Kayıt</button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        function sliderDuzenle(id) {
            $.ajax({
                url: '@Url.Action("SliderGuncelle", "Admin")',
                type: 'POST',
                data: { id: id },
                success: function (data) {
                    if (data != null) {
                        $('#AnasayfaID').val(id);
                        $('#EskiResimYolu').val(data.resim);

                        // Layout'ta summernote zaten başlatıldı, sadece içerik ekle
                        $('#Baslik').summernote('code', data.baslik || '');
                        $('#Icerik').summernote('code', data.icerik || '');
                        $('#summernote').summernote('code', data.aciklama || '');

                        var durum = (data.durum === true || data.durum.toString().toLowerCase() === "true") ? "true" : "false";
                        $('#Durum').val(durum);

                        if (data.resim) {
                            $('#canliResim').attr('src', data.resim);
                            $('#onizlemeKutusu').fadeIn();
                        }
                    }
                }
            });
        }

        function formuTemizle() {
            $('#AnasayfaID').val(0);
            $('#EskiResimYolu').val('');
            $('#sliderForm')[0].reset();

            // Summernote'ları temizle
            $('#Baslik').summernote('code', '');
            $('#Icerik').summernote('code', '');
            $('#summernote').summernote('code', '');

            $('#onizlemeKutusu').fadeOut();
        }
    </script>

    }
