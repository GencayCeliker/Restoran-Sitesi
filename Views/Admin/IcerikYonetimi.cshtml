@using Restorant_Sitesi.Models
@model List<ICERIKLER>
@{
    ViewBag.Title = "IcerikYonetimi";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<h2>IcerikYonetimi</h2>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="row">
    <div class="col-lg-12">
        <div class="card shadow mb-4" style="background: rgba(0, 0, 0, 0.2); border: none; color: white;">
            <div class="card-header py-3 d-flex justify-content-between align-items-center" style="background: transparent; border-bottom: 1px solid rgba(255,255,255,0.1);">
                <h6 class="m-0 font-weight-bold" style="color: #e0e0e0;">Dosya ve İçerik Yönetimi</h6>
                <a href="/Admin/IcerikEkle" class="btn btn-primary btn-sm">YENİ İÇERİK EKLE</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table text-white mb-0">
                        <thead style="background: rgba(0, 0, 0, 0.4);">
                            <tr style="text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">
                                <th>ID</th>
                                <th>Başlık</th>
                                <th>Tarih</th>
                                <th>Dosya / PDF</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model)
                            {
                                <tr>
                                    <td>@x.IcerikID</td>
                                    <td class="text-truncate" style="max-width: 200px;">@x.Baslik</td>
                                    <td>@(x.Tarih.HasValue ? x.Tarih.Value.ToString("dd.MM.yyyy") : "-")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(x.Dosya))
                                        {
                                            <a href="/Dosyalar/@x.Dosya" target="_blank" class="badge badge-info p-2">
                                                <i class="zmdi zmdi-file-text mr-1"></i> DOSYAYI GÖR
                                            </a>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(x.Durum == true ? "badge-success" : "badge-danger")">
                                            @(x.Durum == true ? "AKTİF" : "PASİF")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a href="/Admin/IcerikDuzenle/@x.IcerikID" class="btn btn-sm btn-info mr-1">DÜZENLE</a>
                                        @* SweetAlert tetikleyici sınıf: deleteBtn *@
                                        <button class="btn btn-sm btn-danger deleteBtn" href="/Admin/IcerikSil/@x.IcerikID">SİL</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>$('.deleteBtn').on('click', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');

            Swal.fire({
                title: '<span style="color: #ff0000;">Emin misiniz?</span>',
                text: "Bu içeriği ve bağlı dosyayı silmek istediğinize emin misiniz?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Evet, sil!",
                cancelButtonText: "İptal"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        });</script>
}
