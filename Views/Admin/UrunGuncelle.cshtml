@model Restorant_Sitesi.Models.URUNLER
@{
    ViewBag.Title = "Ürün Güncelle";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow border-0">
                <div class="card-header bg-primary py-3">
                    <h5 class="m-0 font-weight-bold text-white"><i class="fa fa-edit mr-2"></i> Ürün Bilgilerini Güncelle</h5>
                </div>
                <div class="card-body p-4">
                    @using (Html.BeginForm("UrunGuncelle", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(x => x.UrunID)

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Ürün Adı</label>
                                @Html.TextBoxFor(x => x.UrunAd, new { @class = "form-control", placeholder = "Örn: Karışık Izgara", required = "required" })
                            </div>

                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Fiyat (₺)</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text">₺</span>
                                    </div>
                                    @Html.TextBoxFor(x => x.Fiyat, new
                                    {
      @class = "form-control",
      placeholder = "0.00",
      required = "required"
      // type="number" kısmını sildik, böylece virgüllü veriyi olduğu gibi kabul eder
  })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Kategori</label>
                                @Html.DropDownListFor(x => x.KategoriID, (List<SelectListItem>)ViewBag.dgr, "--- Kategori Seçiniz ---", new { @class = "form-control", required = "required" })
                            </div>

                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Satış Durumu</label>
                                @Html.DropDownListFor(x => x.Durum, new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "Aktif (Menüde Görünür)", Value = "true" },
                                    new SelectListItem { Text = "Pasif (Menüde Gizli)", Value = "false" }
                                }, new { @class = "form-control" })
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold text-dark">Ürün İçeriği / Açıklama</label>
                            @Html.TextAreaFor(x => x.Icindekiler, new { @class = "form-control", rows = "3", placeholder = "Ürün içeriğini buraya yazınız..." })
                        </div>

                        <div class="row align-items-center mt-4 p-3 bg-light rounded">
                            <div class="col-md-3 text-center">
                                <label class="d-block font-weight-bold small text-muted">Mevcut Resim</label>
                                @if (!string.IsNullOrEmpty(Model.Resim))
                                {
                                    <img src="@Model.Resim" id="currentImage" class="img-thumbnail shadow-sm" style="max-height: 120px;">
                                }
                                else
                                {
                                    <div class="border rounded d-flex align-items-center justify-content-center bg-white" style="height: 100px;">
                                        <i class="fa fa-image fa-2x text-secondary"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-9">
                                <label class="font-weight-bold text-dark">Resmi Değiştir</label>
                                <div class="custom-file">
                                    <input type="file" name="ResimDosyasi" class="custom-file-input" id="customFile" accept="image/*">
                                    <label class="custom-file-label" for="customFile">Yeni dosya seçiniz...</label>
                                </div>
                                <small class="text-info mt-2 d-block"><i class="fa fa-info-circle"></i> Yeni bir resim seçmezseniz mevcut resim korunacaktır.</small>
                            </div>
                        </div>

                        <hr class="mt-5">

                        <div class="d-flex justify-content-between">
                            <a href="/Admin/UrunListesi" class="btn btn-secondary px-4 shadow-sm">
                                <i class="fa fa-arrow-left mr-1"></i> Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-success px-5 shadow-sm font-weight-bold">
                                <i class="fa fa-check-circle mr-1"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Dosya seçildiğinde adını label'a yazdıralım
        $(".custom-file-input").on("change", function () {
            var fileName = $(this).val().split("\\").pop();
            $(this).siblings(".custom-file-label").addClass("selected").html(fileName);
        });
    </script>
}