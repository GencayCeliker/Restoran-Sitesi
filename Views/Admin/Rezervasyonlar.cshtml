@model  List<Restorant_Sitesi.Models.REZARVASYONLAR>
@{
    ViewBag.Title = "Rezervasyonlar";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<div class="card card-body bg-dark border-light mb-3">
    <form method="get" action="/Admin/Rezervasyonlar" class="form-row align-items-end">
        <div class="col-md-4">
            <label class="text-white">Müşteri Adı</label>
            <input type="text" name="aramaMetni" class="form-control bg-secondary text-white border-0" placeholder="İsim ile ara...">
        </div>
        <div class="col-md-3">
            <label class="text-white">Tarih</label>
            <input type="date" name="aramaTarihi" class="form-control bg-secondary text-white border-0">
        </div>
        <div class="col-md-5">
            <button type="submit" class="btn btn-light"><i class="fa fa-search"></i> Filtrele</button>
            <a href="/Admin/Rezervasyonlar" class="btn btn-outline-light">Temizle</a>
        </div>
    </form>
</div>

<div class="row">
    <div class="col-12 col-lg-12">
        <div class="card">
            <div class="card-header">
                Bekleyen Rezervasyonlar / Son İşlemler
            </div>
            <div class="table-responsive">
                <table class="table align-items-center table-flush table-borderless">
                    <thead>
                        <tr>
                            <th>Müşteri Adı</th>
                            <th>Kişi</th>
                            <th>Tarih</th>
                            <th>Saat</th>
                            <th>Mail</th>
                            <th>Durum</th>
                            <th>İşlem</th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td>@x.MusteriAdSoyad</td>
                                <td>@x.KisiSayisi</td>
                                <td>@(x.Tarih.HasValue ? x.Tarih.Value.ToString("dd.MM.yyyy") : "-")</td>
                                <td>@x.Saat</td>
                                <td>@x.Mail</td>

                                <td>
                                    @if (x.DurumID == 1)
                                    {<span class="badge badge-warning">Beklemede</span> }
                                    else if (x.DurumID == 2)
                                    { <span class="badge badge-success">Onaylandı</span> }
                                    else if (x.DurumID == 3)
                                    { <span class="badge badge-danger">İptal Edildi</span> }
                                    else if (x.DurumID == 4)
                                    { <span class="badge badge-primary">Tamamlandı</span> }
                                    else if (x.DurumID == 5)
                                    { <span class="badge badge-dark">Gelmedi</span>}
                                </td>

                                <td>
                                    @if (x.DurumID == 1) // BEKLİYORSA
                                    {
                                        <button type="button" class="btn btn-sm btn-light"
                                                onclick="ModalAc(@x.RezervasyonID, @x.KisiSayisi, '@x.MusteriAdSoyad')">
                                            Onayla
                                        </button>
                                        <a href="/Admin/RezervasyonIptal/@x.RezervasyonID?returnUrl=@Url.Encode(Request.RawUrl)" class="btn btn-sm btn-light">İptal</a>
                                        <a href="/Admin/RezervasyonTamamla/@x.RezervasyonID?returnUrl=@Url.Encode(Request.RawUrl)" class="btn btn-sm btn-info">Tamamla</a>
                                    }
                                    else if (x.DurumID == 2) // ONAYLIYSA (Müşteri Masadaysa)
                                    {
                                        <div style="margin-bottom:5px;">
                                            <span class="badge badge-success" style="font-size: 12px;">MASA: @(x.MASALAR != null ? x.MASALAR.MasaNo.ToString() : "?")</span>
                                        </div>

                                        <div class="btn-group" role="group">

                                            <a href="/Admin/RezervasyonTamamla/@x.RezervasyonID?returnUrl=@Url.Encode(Request.RawUrl)" class="btn btn-sm btn-info" title="Müşteri Kalktı / Hesabı Kesti">
                                                <i class="fa fa-check-square-o"></i> Kalktı
                                            </a>

                                            <a href="/Admin/RezervasyonGelmedi/@x.RezervasyonID?returnUrl=@Url.Encode(Request.RawUrl)" class="btn btn-sm btn-dark" title="Müşteri Gelmedi">
                                                Gelmedi
                                            </a>

                                            <a href="/Admin/RezervasyonIptal/@x.RezervasyonID?returnUrl=@Url.Encode(Request.RawUrl)" class="btn btn-sm btn-danger" title="İptal Et">
                                                <i class="fa fa-times"></i> İptal Et
                                            </a>
                                            <a href="/Admin/RezervasyonBeklemeyeAl/@x.RezervasyonID?returnUrl=@Url.Encode(Request.RawUrl)" class="btn btn-sm btn-warning" title="Beklemeye Al">
                                                <i class="fa fa-clock-o"></i>Beklemeye Al
                                            </a>
                                        </div>
                                    }
                                    else if (x.DurumID == 4) // TAMAMLANDIYSA
                                    {
                                        <span class="text-white-50" style="font-size:11px;">İşlem Tamam</span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary">-</span>
                                    }
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="MasaSecimModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content" style="background-color: #1a2035; color: white; border: 1px solid rgba(255,255,255,0.1);">

            <div class="modal-header border-light-2">
                <h5 class="modal-title text-white">Rezervasyon Onayla</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <form action="/Admin/RezervasyonOnayla" method="post">
                <div class="modal-body">
                    <input type="hidden" name="rezervasyonId" id="hiddenRezId" />

                    <h6 class="text-white" id="musteriAdiLabel" style="font-weight: bold;"></h6>
                    <hr style="background-color: rgba(255,255,255,0.2);" />
                    <input type="hidden" name="returnUrl" id="modalReturnUrl" />
                    <div class="form-group">
                        <label class="text-white">Uygun Masayı Seçin:</label>
                        <select class="form-control" name="masaId" id="masaSelect" required
                                style="background-color: #2a3042; color: white; border: 1px solid #444;">
                            <option value="">Masa Aranıyor...</option>
                        </select>
                        <small class="text-white-50">Sadece uygun kapasiteli boş masalar listelenir.</small>
                    </div>
                    <div class="form-group mt-2">
                        <label class="text-white">Rezervasyon Tarihi:</label>
                        <input type="date" name="yeniTarih" class="form-control" style="background-color: #2a3042; color: white; border: 1px solid #444;">
                    </div>

                    <div class="form-group mt-2">
                        <label class="text-white">Rezervasyon Saati:</label>
                        <input type="time" name="yeniSaat" class="form-control" style="background-color: #2a3042; color: white; border: 1px solid #444;">
                        <small class="text-white-50">Değişiklik gerekmiyorsa boş bırakabilirsiniz.</small>
                    </div>
                </div>

                <div class="modal-footer border-light-2">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-success">Onayla ve Mail Gönder</button>
                </div>
            </form>

        </div>
    </div>
</div>
@section Scripts {
    <script src="~/AdminTemplate/assets/plugins/Chart.js/Chart.min.js"></script>

    <script>
        // --- 1. MODAL VE MASA GETİRME SCRİPTİ ---
        function ModalAc(rezId, kisiSayisi, musteriAdi) {
            // Rezervasyon bilgilerini doldur
            $('#hiddenRezId').val(rezId);
            $('#musteriAdiLabel').text("Müşteri: " + musteriAdi + " (" + kisiSayisi + " Kişilik)");

            // --- KRİTİK EKLEME: ReturnUrl bilgisini mevcut sayfadan alıp gizli inputa yazar ---
            $('#modalReturnUrl').val(window.location.href);

            // Modal'ı aç
            $('#MasaSecimModal').modal('show');

            // AJAX ile uygun masaları getir
            $.ajax({
                url: '/Admin/GetUygunMasalar',
                type: 'GET',
                data: { kisiSayisi: kisiSayisi },
                success: function (data) {
                    var options = '<option value="">Lütfen Masa Seçiniz</option>';
                    if (data.length > 0) {
                        $.each(data, function (index, item) {
                            options += '<option value="' + item.MasaID + '">Masa ' + item.MasaNo + ' (' + item.Kapasite + ' Kişilik)</option>';
                        });
                    } else {
                        options = '<option value="">Uygun boş masa yok!</option>';
                    }
                    $('#masaSelect').html(options);
                },
                error: function () {
                    console.log("Masa listesi getirilirken bir hata oluştu.");
                }
            });
        }

        // --- 2. GRAFİKLERİ ÇİZEN SCRİPT ---
        $(function () {
            "use strict";

            var chartElement1 = document.getElementById('chart1');
            if (chartElement1) {
                var ctx = chartElement1.getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ["Pzt", "Sal", "Çar", "Per", "Cum", "Cmt", "Paz"],
                        datasets: [{
                            label: 'Ziyaretçi',
                            data: [3, 25, 10, 5, 20, 30, 45],
                            backgroundColor: "rgba(255, 255, 255, 0.2)",
                            borderColor: "rgba(255, 255, 255, 1)",
                            pointBackgroundColor: "rgba(255, 255, 255, 1)",
                            borderWidth: 2
                        }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        legend: { display: false },
                        scales: {
                            xAxes: [{ ticks: { fontColor: "white" }, gridLines: { color: "rgba(255, 255, 255, 0.1)" } }],
                            yAxes: [{ ticks: { fontColor: "white" }, gridLines: { color: "rgba(255, 255, 255, 0.1)" } }]
                        }
                    }
                });
            }

            var chartElement2 = document.getElementById("chart2");
            if (chartElement2) {
                var ctx2 = chartElement2.getContext('2d');
                new Chart(ctx2, {
                    type: 'doughnut',
                    data: {
                        labels: ["Ana Yemek", "Tatlı", "İçecek", "Diğer"],
                        datasets: [{
                            backgroundColor: ["#ffffff", "rgba(255, 255, 255, 0.7)", "rgba(255, 255, 255, 0.5)", "rgba(255, 255, 255, 0.2)"],
                            data: [55, 25, 15, 5],
                            borderWidth: [0, 0, 0, 0]
                        }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        legend: { position: "bottom", labels: { fontColor: '#ddd', boxWidth: 15 } }
                    }
                });
            }
        });
    </script>
}