@model Restorant_Sitesi.Models.URUNLER
@{
    ViewBag.Title = "Yeni Ürün Ekle";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow border-0">
                <div class="card-header bg-info py-3">
                    <h5 class="m-0 font-weight-bold text-white"><i class="fa fa-plus-circle mr-2"></i> Yeni Menü Ürünü Ekle</h5>
                </div>
                <div class="card-body p-4">
                    @using (Html.BeginForm("UrunEkle", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Ürün Adı</label>
                                @Html.TextBoxFor(x => x.UrunAd, new { @class = "form-control", placeholder = "Örn: Adana Kebap", required = "required" })
                            </div>

                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Birim Fiyatı</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-light text-primary font-weight-bold">₺</span>
                                    </div>
                                    @Html.TextBoxFor(x => x.Fiyat, new { @class = "form-control", type = "number", step = "0.01", placeholder = "0.00", required = "required" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Kategori</label>
                                @Html.DropDownListFor(x => x.KategoriID, (List<SelectListItem>)ViewBag.dgr, "--- Kategori Seçiniz ---", new { @class = "form-control", required = "required" })
                            </div>

                            <div class="col-md-6 form-group">
                                <label class="font-weight-bold text-dark">Görünürlük</label>
                                @Html.DropDownListFor(x => x.Durum, new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "Aktif (Hemen Yayınla)", Value = "true" },
                                    new SelectListItem { Text = "Pasif (Daha Sonra)", Value = "false" }
                                }, new { @class = "form-control" })
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold text-dark">Ürün Detayları / Malzemeler</label>
                            @Html.TextAreaFor(x => x.Icindekiler, new { @class = "form-control", rows = "3", placeholder = "Ürünü kısaca tanıtın..." })
                        </div>

                        <div class="form-group mt-4">
                            <label class="font-weight-bold text-dark">Ürün Görseli</label>
                            <div class="custom-file">
                                <input type="file" name="ResimDosyasi" class="custom-file-input" id="imageInput" accept="image/*" required>
                                <label class="custom-file-label" for="imageInput">Görsel seçmek için tıklayın...</label>
                            </div>
                            <small class="text-muted"><i class="fa fa-info-circle"></i> Önerilen boyut: 800x600px. Sadece JPG, PNG formatları.</small>
                        </div>

                        <hr class="mt-5">

                        <div class="d-flex justify-content-between">
                            <a href="/Admin/UrunListesi" class="btn btn-light px-4 border">
                                <i class="fa fa-times mr-1"></i> İptal
                            </a>
                            <button type="submit" class="btn btn-info px-5 shadow-sm font-weight-bold">
                                <i class="fa fa-save mr-1"></i> Ürünü Kaydet
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Dosya adı gösterme ve Dosya gereksinimi kontrolü
        $(".custom-file-input").on("change", function () {
            var fileName = $(this).val().split("\\").pop();
            $(this).siblings(".custom-file-label").addClass("selected").html(fileName);
        });
    </script>
}