@model List<Restorant_Sitesi.Models.SEFLER>

@{
    ViewBag.Title = "Şef Yönetimi";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="container-fluid mt-4">

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark font-weight-bold">
                <i class="fa fa-user-secret text-warning mr-2"></i>Şef Yönetim Paneli
            </h1>
            <p class="text-muted mb-0">Mutfak ekibini buradan yönetebilirsiniz.</p>
        </div>
        <a href="/Admin/KSefEkle" class="btn btn-warning shadow-sm px-4">
            <i class="fa fa-plus-circle mr-2"></i>Yeni Şef Ekle
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-xl-4 col-md-6 mb-3">
            <div class="card border-left-primary shadow h-100 py-2 stat-card">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Toplam Şef</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Count</div>
                        </div>
                        <div class="col-auto"><i class="fa fa-users fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-3">
            <div class="card border-left-success shadow h-100 py-2 stat-card">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Aktif Şef</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Count(x => x.Durum == true)</div>
                        </div>
                        <div class="col-auto"><i class="fa fa-check-circle fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-3">
            <div class="card border-left-danger shadow h-100 py-2 stat-card">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Pasif Şef</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Count(x => x.Durum == false)</div>
                        </div>
                        <div class="col-auto"><i class="fa fa-times-circle fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-lg border-0 main-card">
        <div class="card-header d-flex justify-content-between align-items-center custom-header text-white">
            <h5 class="m-0 font-weight-bold"><i class="fa fa-cutlery mr-2"></i>Mutfak Ekibi</h5>
            <span class="badge badge-light px-3 py-2">@Model.Count() Şef</span>
        </div>

        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle table-hover custom-table">
                        <thead>
                            <tr>
                                <th>Fotoğraf</th>
                                <th>Ad Soyad</th>
                                <th>Uzmanlık</th>
                                <th class="text-center">Durum</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="../../@x.Resim"
                                             alt="@x.SefAdSoyad"
                                             class="chef-img">
                                    </td>
                                    <td class="font-weight-bold text-dark">@x.SefAdSoyad</td>
                                    <td class="text-muted">@x.Uzmanlik</td>
                                    <td class="text-center">
                                        @if (x.Durum == true)
                                        {
                                            <span class="badge badge-success badge-pill px-3 py-2">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger badge-pill px-3 py-2">Pasif</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a href="/Admin/KSefGuncelle/@x.SefID" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                                <i class="fa fa-edit"></i>
                                            </a>
                                            <a href="/Admin/KSefSil/@x.SefID"
                                               class="btn btn-danger"
                                               onclick="return confirm('Bu şefi silmek istediğinize emin misiniz?')">

                                                <i class="fas fa-trash-alt"></i> Sil

                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-area text-center py-5">
                    <i class="fa fa-user-times fa-4x mb-3 text-warning"></i>
                    <h4 class="font-weight-bold">Henüz Şef Bulunmuyor</h4>
                    <a href="/Admin/KSefEkle" class="btn btn-warning mt-2">Şef Ekle</a>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fa fa-trash mr-2"></i>Şef Sil</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="fa fa-exclamation-triangle text-warning fa-4x mb-3"></i>
                <h5 id="chefNameDisplay" class="font-weight-bold text-dark"></h5>
                <p class="text-muted">Bu şefi silmek istediğinize emin misiniz?</p>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Vazgeç</button>
                <a href="#" id="confirmDeleteLink" class="btn btn-danger">Evet, Sil</a>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: #f5f6fa;
    }

    .main-card {
        border-radius: 20px;
        overflow: hidden;
    }

    .custom-header {
        background: linear-gradient(135deg, #141e30, #243b55);
        padding: 18px 25px;
    }

    .custom-table thead th {
        font-size: 12px;
        text-transform: uppercase;
        color: #6c757d;
        border: none;
    }

    .chef-img {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #ffc107;
    }

    .stat-card {
        border-radius: 16px;
        transition: .25s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .border-left-primary {
        border-left: 5px solid #4e73df !important;
    }

    .border-left-success {
        border-left: 5px solid #1cc88a !important;
    }

    .border-left-danger {
        border-left: 5px solid #e74a3b !important;
    }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $(".deleteBtn").click(function () {
            var id = $(this).data("id");
            var name = $(this).data("name");

            // Modal içeriğini doldur
            $("#chefNameDisplay").text(name);

            // Silme linkini oluştur (Controller: KSefler, Action: KSefSil)
            $("#confirmDeleteLink").attr("href", "/Admin/KSefSil/" + id);

            // Modalı göster
            $("#deleteModal").modal("show");
        });
    });
</script>