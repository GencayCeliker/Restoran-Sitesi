@model List<Restorant_Sitesi.Models.KATEGORILER>

@{
    ViewBag.Title = "Kategori Listesi";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/Scripts/jquery-3.7.1.min.js"></script>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark font-weight-bold">Kategori Yönetimi</h2>
        <a href="/Admin/KategoriEkle" class="btn btn-primary shadow-sm">
            <i class="fa fa-plus-circle mr-1"></i> Yeni Kategori Ekle
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 10%;">ID</th>
                        <th>Kategori Adı</th>
                        <th style="width: 25%;" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var x in Model)
                    {
                        <tr>
                            <td>@x.KategoriID</td>
                            <td><strong>@x.KategoriAd</strong></td>
                            <td class="text-center">
                                <a href="/Admin/KategoriGuncelle/@x.KategoriID" class="btn btn-success btn-sm px-3">
                                    <i class="fa fa-edit"></i> Güncelle
                                </a>
                                <a href="/Admin/KategoriSil/@x.KategoriID" class="btn btn-danger btn-sm px-3 deleteBtn">
                                    <i class="fa fa-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    $('.deleteBtn').on('click', function (e) {
            e.preventDefault();
            var url = $(this).attr('href');

            Swal.fire({
                title: '<span style="color: #ff0000;">Emin misiniz?</span>',
                text: "Bu içeriği ve bağlı dosyayı silmek istediğinize emin misiniz?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Evet, sil!",
                cancelButtonText: "İptal"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        });</script>
}
