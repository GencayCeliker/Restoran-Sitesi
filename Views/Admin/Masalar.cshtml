
@{
    ViewBag.Title = "Masalar";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<br /><br />
      <style>
          /* MASA CARD */
          .masa-card {
              border-radius: 15px;
              color: white;
              transition: 0.3s;
              overflow: hidden;
          }

              /* BOŞ MASA */
              .masa-card.bos {
                  background: linear-gradient(135deg, #198754, #157347);
              }

              /* DOLU MASA */
              .masa-card.dolu {
                  background: linear-gradient(135deg, #dc3545, #bb2d3b);
              }

              /* HOVER EFEKT */
              .masa-card:hover {
                  transform: translateY(-5px) scale(1.02);
              }

          /* ICON */
          .status-icon i {
              font-size: 40px;
          }

          /* HEADER */
          .card-header {
              background: rgba(0,0,0,0.2);
              border-bottom: none;
          }

          /* FOOTER */
          .card-footer {
              background: transparent;
              border-top: none;
          }

          /* MASA EKLE CARD */
          .add-card {
              border: 2px dashed #aaa;
              border-radius: 15px;
              background: rgba(255,255,255,0.05);
              color: white;
              transition: 0.3s;
          }

              .add-card:hover {
                  background: rgba(255,255,255,0.1);
                  transform: scale(1.05);
              }
      </style>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
      <div class="row g-4">

          <!-- MASA EKLE CARD -->
          <div class="col-md-3 mb-4">
              <a href="/Admin/MasaEkle" class="text-decoration-none d-block h-100">
                  <div class="card add-card text-center h-100">
                      <div class="card-body d-flex flex-column justify-content-center align-items-center">
                          <i class="fa fa-plus-circle fa-3x mb-3"></i>
                          <h5>Yeni Masa</h5>
                          <small>Masa eklemek için tıkla</small>
                      </div>
                  </div>
              </a>
          </div>

          @foreach (var m in Model)
          {
              var aktifRez = ((List<Restorant_Sitesi.Models.REZARVASYONLAR>)ViewBag.AktifRezervasyonlar)
                             .FirstOrDefault(x => x.MasaID == m.MasaID);

              bool dolu = m.Durum == true;

              <div class="col-md-3">
                  <div class="card masa-card @(dolu ? "dolu" : "bos") shadow">

                      <!-- HEADER -->
                      <div class="card-header d-flex justify-content-between align-items-center">
                          <span class="fw-bold">Masa @m.MasaNo</span>

                          <div>
                              @if (m.Durum == true)
                              {
                                  @* Masa doluysa: JavaScript ile uyarı veriyoruz *@
                                  <a href="javascript:void(0);"
                                     onclick="alert('Masa şu an dolu olduğu için bilgileri güncellenemez. Lütfen önce masayı boşaltın!')"
                                     class="text-white-50 mr-2" style="cursor: not-allowed;">
                                      <i class="fa fa-edit"></i>
                                  </a>
                              }
                              else
                              {
                                  @* Masa boşsa: Normal güncelleme linki çalışır *@
                                  <a href="/Admin/MasaGuncelle/@m.MasaID" class="text-white mr-2">
                                      <i class="fa fa-edit"></i>
                                  </a>
                              }

                              @* Silme butonu (Daha önce yaptığımız gibi) *@
                              @if (m.Durum == false)
                              {
                                  <button class="btn btn-sm text-danger openDeleteModal"
                                          data-url="/Admin/MasaSil/@m.MasaID"
                                          style="background:none; border:none; padding:0;">
                                      <i class="fa fa-trash"></i>
                                  </button>
                              }
                          </div>
                      </div>

                      <!-- BODY -->
                      <div class="card-body text-center">

                          <div class="status-icon mb-3">
                              <i class="fa @(dolu ? "fa-user" : "fa-check-circle")"></i>
                          </div>

                          @if (dolu && aktifRez != null)
                          {
                              <p class="mb-1"><strong>@aktifRez.MusteriAdSoyad</strong></p>
                              <small>@aktifRez.KisiSayisi Kişi • @aktifRez.Saat</small>
                          }
                          else
                          {
                              <p class="mb-1">Masa Boş</p>
                              <small>@m.Kapasite Kişilik</small>
                          }

                      </div>

                      <!-- FOOTER -->
                      <div class="card-footer text-center">
                          @if (dolu && aktifRez != null)
                          {
                              <a href="/Admin/RezervasyonTamamla/@aktifRez.RezervasyonID"
                                 class="btn btn-light btn-sm w-100">
                                  Masayı Boşalt
                              </a>
                          }
                          else
                          {
                              <button class="btn btn-outline-light btn-sm w-100" disabled>
                                  Boş Masa
                              </button>
                          }
                      </div>

                  </div>
              </div>
          }
          <div class="modal fade" id="deleteModal" tabindex="-1">
              <div class="modal-dialog modal-dialog-centered">
                  <div class="modal-content bg-dark text-white">

                      <div class="modal-header border-secondary">
                          <h5 class="modal-title">Silme Onayı</h5>
                          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                      </div>

                      <div class="modal-body">
                          Bu masayı silmek istediğine emin misin?
                      </div>

                      <div class="modal-footer border-secondary">
                          <button class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                          <button id="confirmDeleteBtn" class="btn btn-danger">Evet, Sil</button>
                      </div>

                  </div>
              </div>
          </div>
      </div>
      <script>
          let deleteUrl = "";
          let modal = new bootstrap.Modal(document.getElementById('deleteModal'));

          document.querySelectorAll(".openDeleteModal").forEach(btn => {
              btn.addEventListener("click", function () {
                  deleteUrl = this.getAttribute("data-url");
                  modal.show();
              });
          });

          document.getElementById("confirmDeleteBtn").addEventListener("click", function () {
              window.location.href = deleteUrl;
          });
      </script>
